<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ────────────────────────────────────────────────────────────────
         Thème principal de l'application
         ──────────────────────────────────────────────────────────────── -->
    <style name="Theme.SocialFeed" parent="Theme.Material3.Light.NoActionBar">
        <!-- Couleurs Material 3 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorError">@color/red</item>

        <!-- Barre de statut et navigation -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Typographie -->
        <item name="android:fontFamily">@font/roboto</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- ── Thème Écran de démarrage (Splash Screen) ──────────────────── -->
    <style name="Theme.SocialFeed.Splash" parent="Theme.SocialFeed">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- ── Thème Authentification ─────────────────────────────────────── -->
    <style name="Theme.SocialFeed.Auth" parent="Theme.SocialFeed">
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
